# Ansible managed: Do NOT edit this file manually!

[Unit]
Description=VictoriaLogs service
After=network.target

[Service]
Type=simple
LimitNOFILE={{ vlsingle_max_open_files }}
User={{ vlsingle_system_user }}
Group={{ vlsingle_system_group }}
ExecStart=/usr/local/bin/victoria-logs-prod {% if (vlsingle_service_envflag_enabled | bool) %} -envflag.enable {% endif %} {% for flag, flag_value in vlsingle_service_args.items() %}-{{ flag }}={{ flag_value }} {% endfor %}

SyslogIdentifier=victorialogs
Restart=always

PrivateTmp=yes
ProtectHome=yes
NoNewPrivileges=yes

ProtectSystem=full

{% if vlsingle_systemd_version | int >= 232 %}
ProtectControlGroups=true
ProtectKernelModules=true
ProtectKernelTunables=yes
{% endif %}

{% if vlsingle_service_envflag_enabled | bool %}
{% for v in vlsingle_service_envflag_data %}
Environment="{{ v }}"
{% endfor %}

EnvironmentFile={{ vlsingle_service_envflag_file }}
{% endif %}

[Install]
WantedBy=multi-user.target
