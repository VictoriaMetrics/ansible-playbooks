# Ansible managed: Do NOT edit this file manually!

[Unit]
Description=VictoriaMetrics VMalert service
After=network.target

[Service]
Type=simple
User={{ vmalert_system_user }}
Group={{ vmalert_system_group }}
ExecStart=/usr/local/bin/vmalert-prod {%- for flag, flag_values in _runtime_vmalert_service_args.items() -%}
{%- if flag_values | type_debug == "list" -%}
{% for flag_value in flag_values %} --{{ flag }}={{ flag_value }} {% endfor %}
{% else %} --{{ flag }}={{ flag_values }} {% endif %}
{% endfor %}

SyslogIdentifier={{ vmalert_service_name }}
Restart=always

PrivateTmp=yes
ProtectHome=yes
NoNewPrivileges=yes

ProtectSystem=full

{% if vmalert_systemd_version | int >= 232 %}
ProtectControlGroups=true
ProtectKernelModules=true
ProtectKernelTunables=yes
{% endif %}

[Install]
WantedBy=multi-user.target
