# Ansible managed: Do NOT edit this file manually!

[Unit]
Description=VictoriaTraces service
After=network.target

[Service]
Type=simple
LimitNOFILE={{ vtsingle_max_open_files }}
User={{ vtsingle_system_user }}
Group={{ vtsingle_system_group }}
ExecStart=/usr/local/bin/victoria-traces-prod {% if (vtsingle_service_envflag_enabled | bool) %} -envflag.enable {% endif %} {% for flag, flag_value in vtsingle_service_args.items() %}-{{ flag }}={{ flag_value }} {% endfor %}

SyslogIdentifier=victoriatraces
Restart=always

PrivateTmp=yes
ProtectHome=yes
NoNewPrivileges=yes

ProtectSystem=full

{% if vtsingle_systemd_version | int >= 232 %}
ProtectControlGroups=true
ProtectKernelModules=true
ProtectKernelTunables=yes
{% endif %}

{% if vtsingle_service_envflag_enabled | bool %}
{% for v in vtsingle_service_envflag_data %}
Environment="{{ v }}"
{% endfor %}

EnvironmentFile={{ vtsingle_service_envflag_file }}
{% endif %}

[Install]
WantedBy=multi-user.target
